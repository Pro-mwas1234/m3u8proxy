{
  "version": 2,
  "functions": {
    "src/index.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/m3u8-proxy",
      "dest": "/src/index.js",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/ts-proxy",
      "dest": "/src/index.js",
      "headers": {
        "Access-Control-Allow-Origin": "*"
      }
    },
    {
      "src": "/",
      "dest": "/src/index.html"
    },
    {
      "src": "/index.html",
      "dest": "/src/index.html"
    }
  ]
}
